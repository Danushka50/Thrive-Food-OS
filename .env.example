# Optional for local development.
# If you leave this unset on localhost, the app will automatically use
# http://<current-host>:5000/api.
VITE_API_BASE_URL=http://localhost:5000/api

# Vercel frontend project example:
# VITE_API_BASE_URL=https://your-backend.vercel.app/api
# If you prefer same-origin requests on Vercel, keep this unset and make sure
# vercel.json proxies /api/* and /uploads/* to the backend deployment.

# Pusher Channels client configuration
VITE_PUSHER_KEY=your_pusher_key
VITE_PUSHER_CLUSTER=ap2
