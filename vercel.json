{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://thrive-backend-five.vercel.app/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://thrive-backend-five.vercel.app/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
